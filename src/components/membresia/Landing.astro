---
<!DOCTYPE html>
<html lang={t.htmlLang}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{t.metaTitle}</title>
<meta name="description" content={t.metaDesc} />
<link rel="icon" href="https://emilserios.com/wp-content/uploads/2025/06/cropped-emilserios-32x32.png" sizes="32x32" />
<link rel="stylesheet" href="/colors_and_type.css" />
<style is:inline>
  :root {
    --ink:#0c0c0c; --paper:#ffffff; --color-text:#0c0c0c;
    --color-accent:#0c0c0c; --color-accent-strong:#000000;
    --color-border:#e4e2dd; --color-text-soft:#71706b;
    --edge: clamp(20px, 5vw, 72px);
  }
  html { scroll-behavior: smooth; }
  body { background: var(--paper); color: var(--ink); overflow-x: hidden; }
  ::selection { background: #0c0c0c; color: #fff; }
  a { color: inherit; }
  img { display: block; max-width: 100%; }
  .display { font-family: var(--font-display); font-weight: var(--weight-medium);
             letter-spacing: -0.035em; line-height: 0.92; text-wrap: balance; }
  .ovl { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-semibold);
         letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-text-soft); }

  .bar { position: fixed; inset: 0 0 auto 0; z-index: 80;
         display: flex; align-items: center; justify-content: space-between;
         padding: clamp(14px, 2.2vw, 22px) var(--edge);
         mix-blend-mode: difference; color: #fff; }
  .bar a, .bar button { color: #fff; }
  .mark { font-family: var(--font-display); font-weight: var(--weight-semibold);
          font-size: var(--text-md); letter-spacing: -0.02em; text-decoration: none;
          line-height: 1; display: inline-flex; align-items: baseline; gap: 0.5em; }
  .mark small { font-family: var(--font-body); font-weight: var(--weight-medium);
                font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.7; }
  .bar__actions { display: inline-flex; align-items: center; gap: clamp(16px, 2.5vw, 28px); }
  .lang { display: inline-flex; align-items: center; gap: 4px; font-family: var(--font-body);
          font-size: var(--text-sm); font-weight: var(--weight-semibold); letter-spacing: 0.08em; }
  .lang a { text-decoration: none; padding: 3px 6px; border-radius: var(--radius-full); opacity: 0.5;
            transition: opacity var(--duration) var(--ease); }
  .lang a[aria-current="true"] { opacity: 1; text-decoration: underline; text-underline-offset: 4px; }
  .lang span { opacity: 0.4; }
  .menu-btn { appearance: none; background: none; border: 0; cursor: pointer;
              display: inline-flex; align-items: center; gap: 12px;
              font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-semibold);
              letter-spacing: 0.16em; text-transform: uppercase; padding: 6px 0; }
  .menu-btn__bars { display: inline-flex; flex-direction: column; gap: 5px; width: 26px; }
  .menu-btn__bars i { height: 1.5px; width: 100%; background: currentColor; display: block; }

  .overlay { position: fixed; inset: 0; z-index: 70; background: var(--ink); color: #f4f3ef;
             padding: clamp(80px, 12vh, 140px) var(--edge) clamp(28px, 5vh, 56px);
             display: grid; grid-template-rows: 1fr auto; clip-path: inset(0 0 100% 0);
             pointer-events: none; transition: clip-path 620ms cubic-bezier(0.76, 0, 0.24, 1); }
  .overlay.open { clip-path: inset(0 0 0 0); pointer-events: auto; }
  body.menu-open { overflow: hidden; }
  .bar { transition: opacity 240ms var(--ease); }
  body.menu-open .bar { opacity: 0; visibility: hidden; pointer-events: none; }
  .ov-nav { display: flex; flex-direction: column; justify-content: center; gap: clamp(2px, 0.5vh, 8px); }
  .ov-link { position: relative; display: flex; align-items: baseline; gap: clamp(16px, 2vw, 32px);
             text-decoration: none; color: #f4f3ef; padding: clamp(4px, 1vh, 14px) 0;
             border-bottom: 1px solid rgba(255,255,255,0.12);
             opacity: 0; transform: translateY(26px);
             transition: opacity 600ms var(--ease), transform 600ms var(--ease), color var(--duration) var(--ease); }
  .overlay.open .ov-link { opacity: 1; transform: none; }
  .overlay.open .ov-link:nth-child(1) { transition-delay: 140ms; }
  .overlay.open .ov-link:nth-child(2) { transition-delay: 210ms; }
  .overlay.open .ov-link:nth-child(3) { transition-delay: 280ms; }
  .ov-link__num { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-semibold);
                  letter-spacing: 0.1em; color: #8a8884; min-width: 2.4em; }
  .ov-link__word { font-family: var(--font-display); font-weight: var(--weight-medium);
                   letter-spacing: -0.03em; line-height: 1; font-size: clamp(2.4rem, 9vw, 7rem); }
  .ov-link__es { font-family: var(--font-body); font-style: italic; font-weight: var(--weight-regular);
                 color: #8a8884; font-size: var(--text-md); margin-left: auto; align-self: center; }
  .ov-link .arrow { align-self: center; font-size: var(--text-xl); color: #8a8884;
                    transform: translateX(-8px); opacity: 0; transition: all var(--duration) var(--ease); }
  .ov-link:hover { color: #fff; }
  .ov-link:hover .arrow { transform: none; opacity: 1; color: #fff; }
  .ov-link:hover .ov-link__es { color: #cfceca; }
  .ov-foot { display: flex; flex-wrap: wrap; gap: var(--space-3) var(--space-6); align-items: baseline;
             justify-content: space-between; padding-top: var(--space-4);
             border-top: 1px solid rgba(255,255,255,0.12); }
  .ov-foot .group { display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-5); }
  .ov-foot a { color: #b9b8b3; text-decoration: none; font-size: var(--text-sm); letter-spacing: 0.02em;
               transition: color var(--duration) var(--ease); }
  .ov-foot a:hover { color: #fff; }
  .ov-foot .lbl { color: #6f6e6a; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; }
  .ov-close { position: absolute; top: clamp(20px, 3vh, 34px); right: var(--edge);
              appearance: none; background: none; border: 0; cursor: pointer; color: #f4f3ef;
              font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-semibold);
              letter-spacing: 0.16em; text-transform: uppercase; display: inline-flex; align-items: center; gap: 10px; }
  .ov-close span { font-size: var(--text-lg); line-height: 0; }

  .pay {
    --pay-fg: var(--ink); --pay-fill: var(--ink); --pay-fg-hover: var(--paper);
    --mx: 50%; --my: 50%;
    position: relative; isolation: isolate; overflow: hidden;
    display: inline-flex; align-items: center; gap: 14px;
    padding: clamp(17px, 2vw, 22px) clamp(26px, 3vw, 36px);
    border: 1.5px solid var(--ink); border-radius: var(--radius-full);
    background: transparent; color: var(--pay-fg); cursor: pointer;
    font-family: var(--font-display); font-weight: var(--weight-medium);
    font-size: clamp(var(--text-md), 1.4vw, var(--text-lg)); letter-spacing: -0.015em;
    text-decoration: none; white-space: nowrap;
    transition: color 360ms var(--ease), transform 420ms cubic-bezier(.22,1,.36,1), box-shadow 420ms var(--ease);
    will-change: transform;
  }
  .pay__fill { position: absolute; top: var(--my); left: var(--mx);
               width: 260%; aspect-ratio: 1; z-index: -1;
               background: var(--pay-fill); border-radius: 50%;
               transform: translate(-50%, -50%) scale(0); transform-origin: center;
               transition: transform 560ms cubic-bezier(.22,1,.36,1); }
  .pay:hover { color: var(--pay-fg-hover); }
  .pay:hover .pay__fill { transform: translate(-50%, -50%) scale(1); }
  .pay:active { transform: translateY(1px) scale(0.99); }
  .pay__ar { display: inline-block; transition: transform 360ms cubic-bezier(.22,1,.36,1); }
  .pay:hover .pay__ar { transform: translateX(6px); }
  .pay--ring::after { content: ""; position: absolute; inset: -3px; border-radius: inherit;
                      border: 1.5px solid var(--ink); opacity: 0; z-index: -2; pointer-events: none;
                      animation: payring 3.6s var(--ease) infinite; }
  @keyframes payring { 0% { transform: scale(1); opacity: .45; } 70%, 100% { transform: scale(1.16); opacity: 0; } }
  .pay--invert { --pay-fg: var(--ink); --pay-fill: var(--ink); --pay-fg-hover: var(--paper);
                 background: var(--paper); border-color: var(--paper);
                 box-shadow: 0 1px 0 rgba(255,255,255,0.4); }
  .pay--invert.pay--ring::after { border-color: rgba(255,255,255,0.55); }

  .hero { min-height: 100svh; position: relative;
          display: grid; grid-template-columns: 1.08fr 0.92fr; align-items: stretch; }
  .hero__text { padding: clamp(104px, 13vh, 168px) clamp(20px, 3vw, 44px) clamp(40px, 6vh, 72px) var(--edge);
                display: flex; flex-direction: column; justify-content: center; gap: clamp(22px, 3.4vh, 40px); }
  .hero__eyebrow { display: flex; align-items: center; gap: 14px; }
  .hero__eyebrow .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--ink);
                        animation: pulse 2.6s var(--ease) infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.25; } }
  .hero__title { font-size: clamp(3rem, 8.4vw, 9rem); margin: 0; }
  .hero__title em { font-style: italic; font-weight: var(--weight-regular); color: var(--color-text-soft);
                    display: block; font-size: 0.42em; letter-spacing: -0.01em; margin-top: 0.34em; }
  .hero__gloss { max-width: 34ch; color: #3a3a38; font-size: var(--text-md); line-height: 1.5; }
  .hero__cta { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; margin-top: var(--space-2); }
  .hero__note { font-size: var(--text-sm); color: var(--color-text-soft); }
  .hero__note b { color: var(--ink); font-weight: var(--weight-semibold); }
  .hero__media { position: relative; overflow: hidden; background: #efeee9; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 34%;
                     filter: grayscale(1) contrast(1.04); transform: scale(1.02);
                     transition: filter 900ms var(--ease), transform 1200ms var(--ease); }
  .hero:hover .hero__media img { filter: grayscale(0) contrast(1); transform: scale(1); }
  .hero__credit { position: absolute; left: 16px; bottom: 14px; color: #fff; mix-blend-mode: difference;
                  font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; }
  .hero__tag { position: absolute; right: 16px; top: clamp(96px, 13vh, 150px); color: #fff;
               mix-blend-mode: difference; text-align: right; }
  .hero__tag b { display: block; font-family: var(--font-display); font-weight: var(--weight-medium);
                 font-size: var(--text-xl); letter-spacing: -0.02em; }
  .hero__tag span { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.8; }

  .marquee { border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);
             overflow: hidden; padding: clamp(14px, 2vw, 22px) 0; }
  .marquee__track { display: inline-flex; gap: 0; white-space: nowrap; will-change: transform;
                    animation: scroll-x 36s linear infinite; }
  .marquee:hover .marquee__track { animation-play-state: paused; }
  .marquee__track span { font-family: var(--font-display); font-weight: var(--weight-medium);
                         font-size: clamp(1.4rem, 3vw, 2.6rem); letter-spacing: -0.02em; padding: 0 var(--space-5); }
  .marquee__track span i { font-style: normal; color: var(--color-text-soft); }
  @keyframes scroll-x { to { transform: translateX(-50%); } }

  .how { padding: clamp(72px, 12vh, 150px) var(--edge); }
  .how__inner { max-width: 1180px; margin: 0 auto; }
  .how__head { max-width: 30ch; margin-bottom: clamp(40px, 6vh, 72px); }
  .how__head h2 { font-family: var(--font-display); font-weight: var(--weight-medium);
                  font-size: clamp(2rem, 4.4vw, 3.6rem); letter-spacing: -0.035em; line-height: 1.0;
                  margin-top: var(--space-3); }
  .how__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(20px, 3vw, 40px);
               border-top: 1px solid var(--ink); }
  .step { padding-top: var(--space-4); }
  .step__day { font-family: var(--font-body); font-size: var(--text-sm); font-weight: var(--weight-semibold);
               letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-text-soft); }
  .step__num { font-family: var(--font-display); font-weight: var(--weight-medium);
               font-size: clamp(2.6rem, 5vw, 4rem); letter-spacing: -0.04em; line-height: 1;
               margin: var(--space-3) 0 var(--space-3); }
  .step h3 { font-family: var(--font-display); font-weight: var(--weight-medium);
             font-size: var(--text-xl); letter-spacing: -0.025em; margin-bottom: 8px; }
  .step p { color: #3a3a38; font-size: var(--text-base); line-height: 1.55; max-width: 34ch; }

  .incl { padding: 0 var(--edge) clamp(72px, 12vh, 150px); }
  .incl__inner { max-width: 1180px; margin: 0 auto; }
  .incl__head { display: flex; align-items: flex-end; justify-content: space-between;
                gap: var(--space-4); margin-bottom: var(--space-6); flex-wrap: wrap; }
  .incl__head h2 { font-family: var(--font-display); font-weight: var(--weight-medium);
                   font-size: clamp(1.8rem, 3.6vw, 3rem); letter-spacing: -0.03em; }
  .ilist { border-top: 1px solid var(--color-border); }
  .irow { display: grid; grid-template-columns: 3.2em 1fr; gap: clamp(12px, 3vw, 48px);
          align-items: baseline; padding: clamp(20px, 3vw, 34px) 0;
          border-bottom: 1px solid var(--color-border); transition: padding-left var(--duration) var(--ease); }
  .irow:hover { padding-left: 14px; }
  .irow__num { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-soft);
               font-weight: var(--weight-semibold); }
  .irow__title { font-family: var(--font-display); font-weight: var(--weight-medium);
                 font-size: clamp(1.35rem, 2.6vw, 2rem); letter-spacing: -0.025em; line-height: 1.08; }
  .irow__desc { color: var(--color-text-soft); font-size: var(--text-base); margin-top: 8px;
                max-width: 56ch; line-height: 1.5; }

  .focus { background: var(--ink); color: #f4f3ef; padding: clamp(80px, 14vh, 168px) var(--edge); }
  .focus__inner { max-width: 1100px; margin: 0 auto;
                  display: grid; grid-template-columns: 0.42fr 0.58fr; gap: clamp(28px, 6vw, 90px); }
  .focus__aside { align-self: start; }
  .focus__aside .ovl { color: #8a8884; }
  .focus__aside h2 { font-family: var(--font-display); color: #fff; font-weight: var(--weight-medium);
                     font-size: clamp(1.9rem, 3.6vw, 3rem); letter-spacing: -0.035em; line-height: 1.02;
                     margin-top: var(--space-3); }
  .focus__body { font-size: var(--text-md); line-height: 1.62; color: #cbcac6; }
  .focus__body p { margin-bottom: 1.1em; max-width: 56ch; }
  .focus__body strong { color: #fff; font-weight: var(--weight-semibold); }
  .focus__pull { font-family: var(--font-display); font-weight: var(--weight-medium); color: #fff;
                 font-size: clamp(1.5rem, 3vw, 2.2rem); letter-spacing: -0.03em; line-height: 1.08;
                 margin: 1em 0; max-width: 24ch; }

  .plan { padding: clamp(80px, 14vh, 170px) var(--edge); }
  .plan__inner { max-width: 980px; margin: 0 auto; }
  .plan__head { text-align: center; margin-bottom: clamp(36px, 5vh, 56px); }
  .plan__head h2 { font-family: var(--font-display); font-weight: var(--weight-medium);
                   font-size: clamp(2.2rem, 5vw, 4.4rem); letter-spacing: -0.035em; line-height: 0.98; }
  .plan__head p { color: var(--color-text-soft); font-size: var(--text-md); margin: var(--space-4) auto 0;
                  max-width: 44ch; line-height: 1.5; }
  .card { border: 1px solid var(--ink); border-radius: var(--radius-lg); overflow: hidden;
          display: grid; grid-template-columns: 1.05fr 0.95fr; }
  .card__left { padding: clamp(32px, 4vw, 52px); border-right: 1px solid var(--color-border); }
  .card__name { font-family: var(--font-display); font-weight: var(--weight-medium);
                font-size: var(--text-xl); letter-spacing: -0.02em; }
  .card__name span { font-style: italic; font-weight: var(--weight-regular); color: var(--color-text-soft);
                     font-size: 0.7em; }
  .card__price { display: flex; align-items: baseline; gap: 10px; margin: var(--space-4) 0 4px; }
  .card__amount { font-family: var(--font-display); font-weight: var(--weight-medium);
                  font-size: clamp(3.4rem, 8vw, 5.2rem); letter-spacing: -0.04em; line-height: 0.9; }
  .card__per { color: var(--color-text-soft); font-size: var(--text-md); }
  .card__sub { color: var(--color-text-soft); font-size: var(--text-sm); margin-top: var(--space-3); }
  .card__right { padding: clamp(32px, 4vw, 52px); display: flex; flex-direction: column;
                 justify-content: space-between; gap: var(--space-5); background: #faf9f7; }
  .checks { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .checks li { display: grid; grid-template-columns: 22px 1fr; gap: 12px; align-items: start;
               font-size: var(--text-base); line-height: 1.4; }
  .checks .tick { font-family: var(--font-display); line-height: 1; font-size: var(--text-md); }
  .card__action { display: flex; flex-direction: column; gap: 12px; align-items: stretch; }
  .card__action .pay { justify-content: center; }
  .card__fine { font-size: var(--text-sm); color: var(--color-text-soft); text-align: center; }

  .faq { padding: 0 var(--edge) clamp(72px, 12vh, 150px); }
  .faq__inner { max-width: 1180px; margin: 0 auto;
                display: grid; grid-template-columns: 0.4fr 0.6fr; gap: clamp(28px, 6vw, 90px); }
  .faq__aside h2 { font-family: var(--font-display); font-weight: var(--weight-medium);
                   font-size: clamp(1.9rem, 3.6vw, 3rem); letter-spacing: -0.035em; line-height: 1.0;
                   margin-top: var(--space-3); }
  .qa { border-top: 1px solid var(--color-border); }
  .qitem { border-bottom: 1px solid var(--color-border); }
  .qitem summary { list-style: none; cursor: pointer; display: flex; align-items: center;
                   justify-content: space-between; gap: var(--space-4);
                   padding: clamp(20px, 2.6vw, 28px) 0;
                   font-family: var(--font-display); font-weight: var(--weight-medium);
                   font-size: clamp(1.15rem, 2.2vw, 1.5rem); letter-spacing: -0.02em; }
  .qitem summary::-webkit-details-marker { display: none; }
  .qitem .pm { flex: none; width: 22px; height: 22px; position: relative; }
  .qitem .pm::before, .qitem .pm::after { content: ""; position: absolute; inset: 0; margin: auto;
        background: var(--ink); transition: transform var(--duration) var(--ease), opacity var(--duration) var(--ease); }
  .qitem .pm::before { width: 100%; height: 1.5px; }
  .qitem .pm::after { width: 1.5px; height: 100%; }
  .qitem[open] .pm::after { transform: scaleY(0); opacity: 0; }
  .qitem__a { overflow: hidden; color: #3a3a38; font-size: var(--text-base); line-height: 1.6;
              max-width: 60ch; padding-bottom: clamp(20px, 2.6vw, 28px); }

  .foot { border-top: 1px solid var(--ink); padding: clamp(56px, 9vh, 110px) var(--edge) clamp(28px, 4vh, 48px); }
  .foot__big { font-family: var(--font-display); font-weight: var(--weight-medium);
               font-size: clamp(2.4rem, 11vw, 10rem); letter-spacing: -0.04em; line-height: 0.86;
               margin-bottom: clamp(40px, 7vh, 90px); }
  .foot__big em { font-style: italic; font-weight: var(--weight-regular); color: var(--color-text-soft); }
  .foot__cols { display: grid; grid-template-columns: 1.4fr repeat(3, 0.8fr); gap: var(--space-5);
                padding-bottom: var(--space-6); border-bottom: 1px solid var(--color-border); }
  .foot__col h4 { font-family: var(--font-body); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
                  color: var(--color-text-soft); font-weight: var(--weight-semibold); margin-bottom: var(--space-3); }
  .foot__col a { display: block; text-decoration: none; color: var(--ink); font-size: var(--text-base);
                 margin-bottom: 8px; width: fit-content; transition: opacity var(--duration) var(--ease); }
  .foot__col a:hover { opacity: 0.5; }
  .foot__col p { color: var(--color-text-soft); font-size: var(--text-sm); line-height: 1.5; }
  .foot__base { display: flex; justify-content: space-between; gap: var(--space-4); flex-wrap: wrap;
                padding-top: var(--space-4); color: var(--color-text-soft); font-size: var(--text-sm); }
  .foot__base em { font-style: italic; }

  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 760ms var(--ease), transform 760ms var(--ease); }
  .reveal.in { opacity: 1; transform: none; }

  @media (max-width: 960px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero__text { padding-top: clamp(110px, 18vh, 160px); }
    .hero__media { height: 72vh; order: 2; }
    .hero:hover .hero__media img, .hero__media img { filter: grayscale(0) contrast(1); transform: scale(1); }
    .hero__tag { top: auto; bottom: 48px; }
    .how__grid { grid-template-columns: 1fr; gap: 0; }
    .step { border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-5); }
    .step:last-child { border-bottom: 0; }
    .focus__inner { grid-template-columns: 1fr; gap: var(--space-5); }
    .card { grid-template-columns: 1fr; }
    .card__left { border-right: 0; border-bottom: 1px solid var(--color-border); }
    .faq__inner { grid-template-columns: 1fr; gap: var(--space-5); }
    .foot__cols { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .foot__cols { grid-template-columns: 1fr; }
    .ov-link__es { display: none; }
    .irow { grid-template-columns: 2.4em 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0.001ms !important; animation-iteration-count: 1 !important; }
    .reveal { opacity: 1; transform: none; }
    .marquee__track { animation: none; }
    .pay--ring::after { display: none; }
  }
</style>
</head>
<body>

  <header class="bar">
    <a class="mark" href="#top" aria-label="Emilse Rios">
      Emilse Rios <small>{t.role}</small>
    </a>
    <div class="bar__actions">
      <div class="lang" aria-label="Idioma / Language">
        <a href="/" aria-current={(!isEN).toString()}>ES</a>
        <span aria-hidden="true">/</span>
        <a href="/en/" aria-current={isEN.toString()}>EN</a>
      </div>
      <button class="menu-btn" id="menuOpen" aria-expanded="false" aria-controls="overlay">
        {t.menu}
        <span class="menu-btn__bars" aria-hidden="true"><i></i><i></i></span>
      </button>
    </div>
  </header>

  <div class="overlay" id="overlay" role="dialog" aria-modal="true" aria-label={t.menu}>
    <button class="ov-close" id="menuClose">{t.close} <span>&times;</span></button>
    <nav class="ov-nav">
      {t.nav.map((n) => (
        <a class="ov-link" href={n.href}>
          <span class="ov-link__num">{n.num}</span>
          <span class="ov-link__word">{n.word}</span>
          <span class="ov-link__es">{n.es}</span>
          <span class="arrow" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </nav>
    <div class="ov-foot">
      <div class="group">
        <span class="lbl">{t.more}</span>
        <a href="https://emilserios.com/cursos-contrabajo/">{t.courses}</a>
        <a href="https://emilserios.com/videos/">{t.videos}</a>
        <a href="https://emilserios.com/dashboard">{t.classroom}</a>
      </div>
      <div class="group">
        <span class="lbl">{t.online}</span>
        <a href="https://www.instagram.com/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.youtube.com/" target="_blank" rel="noopener">YouTube</a>
        <a href="mailto:hola@emilserios.com">Email</a>
      </div>
      <span class="lbl">Madrid</span>
    </div>
  </div>

  <main id="top">

    <section class="hero">
      <div class="hero__text">
        <div class="hero__eyebrow ovl"><span class="dot"></span> {t.heroEyebrow}</div>
        <h1 class="hero__title display">{t.heroTitle}<em>{t.heroTitleEm}</em></h1>
        <p class="hero__gloss">{t.heroGloss}</p>
        <div class="hero__cta">
          <a class="pay pay--ring" href="#plan" data-magnetic>
            <span class="pay__fill" aria-hidden="true"></span>
            {t.heroCta} <span class="pay__ar" aria-hidden="true">&rarr;</span>
          </a>
          <span class="hero__note"><b>{t.heroNote1}</b> · {t.heroNote2}</span>
        </div>
      </div>
      <div class="hero__media">
        <img src="/emi-city.jpg" alt="Emilse Rios" />
        <div class="hero__tag">
          <b>{t.heroTagB}</b>
          <span>{t.heroTagS}</span>
        </div>
        <span class="hero__credit">Madrid</span>
      </div>
    </section>

    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        <span set:html={t.marquee + '&nbsp;'} />
        <span set:html={t.marquee + '&nbsp;'} />
      </div>
    </div>

    <section class="how" id="how">
      <div class="how__inner">
        <div class="how__head reveal">
          <span class="ovl">{t.howEyebrow}</span>
          <h2>{t.howH2}</h2>
        </div>
        <div class="how__grid">
          {t.steps.map((s) => (
            <div class="step reveal">
              <span class="step__day">{s.day}</span>
              <div class="step__num">{s.num}</div>
              <h3>{s.h}</h3>
              <p>{s.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="incl" id="incluye">
      <div class="incl__inner">
        <div class="incl__head reveal">
          <h2>{t.inclH2}</h2>
          <span class="ovl">{t.inclEyebrow}</span>
        </div>
        <div class="ilist reveal">
          {t.incl.map((it, i) => (
            <div class="irow">
              <span class="irow__num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <div class="irow__title">{it.t}</div>
                <p class="irow__desc">{it.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="focus">
      <div class="focus__inner">
        <aside class="focus__aside reveal">
          <span class="ovl">{t.focusEyebrow}</span>
          <h2>{t.focusH2}</h2>
        </aside>
        <div class="focus__body reveal">
          <p>{t.focusP1}</p>
          <p class="focus__pull">{t.focusPull}</p>
          <p>{t.focusP2}</p>
          <p set:html={t.focusP3} />
        </div>
      </div>
    </section>

    <section class="plan" id="plan">
      <div class="plan__inner">
        <div class="plan__head reveal">
          <h2 class="display">{t.planH2}</h2>
          <p>{t.planSub}</p>
        </div>
        <div class="card reveal">
          <div class="card__left">
            <div class="card__name">{t.cardName} <span>{t.cardNameEs}</span></div>
            <div class="card__price">
              <span class="card__amount">19&nbsp;€</span>
              <span class="card__per">{t.per}</span>
            </div>
            <p class="card__sub">{t.cardSub}</p>
          </div>
          <div class="card__right">
            <ul class="checks">
              {t.checks.map((c) => (
                <li><span class="tick" aria-hidden="true">→</span> {c}</li>
              ))}
            </ul>
            <div class="card__action">
              <a class="pay pay--invert pay--ring" href="#" id="payMain" data-magnetic>
                <span class="pay__fill" aria-hidden="true"></span>
                {t.payMain} <span class="pay__ar" aria-hidden="true">&rarr;</span>
              </a>
              <span class="card__fine">{t.cardFine}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="faq">
      <div class="faq__inner">
        <aside class="faq__aside reveal">
          <span class="ovl">{t.faqEyebrow}</span>
          <h2>{t.faqH2}</h2>
        </aside>
        <div class="qa reveal">
          {t.faq.map((f) => (
            <details class="qitem">
              <summary>{f.q} <span class="pm" aria-hidden="true"></span></summary>
              <div class="qitem__a">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <footer class="foot">
      <div class="foot__big display">{t.footBig} <em>{t.footBigEm}</em></div>
      <div class="foot__cols">
        <div class="foot__col">
          <h4>Emilse Rios</h4>
          <p>{t.footAbout}</p>
        </div>
        <div class="foot__col">
          <h4>{t.footMembership}</h4>
          <a href="#how">{t.footHow}</a>
          <a href="#incluye">{t.footIncl}</a>
          <a href="#plan">{t.footPlan}</a>
        </div>
        <div class="foot__col">
          <h4>{t.footMore}</h4>
          <a href="https://emilserios.com/cursos-contrabajo/">{t.courses}</a>
          <a href="https://emilserios.com/videos/">{t.videos}</a>
          <a href="https://emilserios.com/dashboard">{t.classroom}</a>
        </div>
        <div class="foot__col">
          <h4>{t.online}</h4>
          <a href="https://www.instagram.com/" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.youtube.com/" target="_blank" rel="noopener">YouTube</a>
          <a href="mailto:hola@emilserios.com">Email</a>
        </div>
      </div>
      <div class="foot__base">
        <span>{t.footBase1}</span>
        <span set:html={t.footBase2} />
      </div>
    </footer>

  </main>

<script is:inline>
  (function () {
    var body = document.body;
    var overlay = document.getElementById('overlay');
    var openBtn = document.getElementById('menuOpen');
    var closeBtn = document.getElementById('menuClose');
    function openMenu() { overlay.classList.add('open'); body.classList.add('menu-open'); openBtn.setAttribute('aria-expanded', 'true'); }
    function closeMenu() { overlay.classList.remove('open'); body.classList.remove('menu-open'); openBtn.setAttribute('aria-expanded', 'false'); }
    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', function (e) { if (e.target.closest('.ov-link, .ov-foot a')) closeMenu(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && overlay.classList.contains('open')) closeMenu(); });

    var fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    document.querySelectorAll('.pay[data-magnetic]').forEach(function (btn) {
      btn.addEventListener('pointermove', function (e) {
        var r = btn.getBoundingClientRect();
        var x = e.clientX - r.left, y = e.clientY - r.top;
        btn.style.setProperty('--mx', x + 'px');
        btn.style.setProperty('--my', y + 'px');
        if (fine && !reduce) {
          var dx = (x - r.width / 2) / r.width, dy = (y - r.height / 2) / r.height;
          btn.style.transform = 'translate(' + (dx * 10).toFixed(2) + 'px,' + (dy * 8).toFixed(2) + 'px)';
        }
      });
      btn.addEventListener('pointerleave', function () { btn.style.transform = ''; });
    });

    var payMain = document.getElementById('payMain');
    if (payMain) payMain.addEventListener('click', function (e) {
      e.preventDefault();
      payMain.querySelector('.pay__ar').textContent = '✓';
      var fine2 = payMain.closest('.card__action').querySelector('.card__fine');
      if (fine2) fine2.textContent = '…';
    });

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { entry.target.classList.add('in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.16 });
    document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
  })();
</script>
</body>
</html>
