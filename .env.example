# ---- Supabase (frontend, públicas) ----
# Las consigues en supabase.com → tu proyecto → Project Settings → API
PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key...

# ---- Supabase (solo servidor, NUNCA exponer en el navegador) ----
# Se usa en el webhook de Stripe (paso 5). No la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# ---- Stripe (paso 5) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
